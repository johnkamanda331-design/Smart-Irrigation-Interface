{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "moduleResolution": "nodenext",
    "baseUrl": ".",
    "paths": {
      "@workspace/*": ["../lib/*/src/index.ts"],
      "@workspace/db": ["../lib/db/src/index.ts"],
      "@workspace/api-zod": ["../lib/api-zod/src/index.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
