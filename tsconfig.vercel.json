{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": ".vercel_build_output",
    "rootDir": ".",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@workspace/*": ["./lib/*", "./artifacts/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["api/**/*", "lib/**/*"],
  "exclude": ["node_modules", "dist", "artifacts"],
  "references": [
    {
      "path": "./lib/db"
    },
    {
      "path": "./lib/api-zod"
    }
  ]
}
