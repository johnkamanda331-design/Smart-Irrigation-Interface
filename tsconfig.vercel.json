{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": ".vercel_build_output",
    "rootDir": ".",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@workspace/api-zod": ["./lib/api-zod/src/index.ts"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules", "dist", "artifacts", "lib"],
  "references": [
    {
      "path": "./lib/db",
      "prepend": true
    },
    {
      "path": "./lib/api-zod",
      "prepend": true
    }
  ]
}
